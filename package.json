{
  "name": "study-compass",
  "version": "0.1.0",
  "private": true,
  "description": "Mobile-first Android study planning app with a web preview.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "api": "node server/index.js",
    "start": "concurrently \"npm run api\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "android:init": "npm run build && cap add android",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.4.4",
    "@capacitor/splash-screen": "^7.0.5",
    "@capacitor/status-bar": "^7.0.6",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "pg": "^8.21.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4"
  }
}
